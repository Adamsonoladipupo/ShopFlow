  <diagram name="Inventory Service Sequence Diagram by Abdulwahab ADamson" id="lk6a5qE4FISdLqHVQsB1">
    <mxGraphModel dx="1014" dy="619" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="827" math="0" shadow="0">
      <root>
        <mxCell id="HsMK0yCQirDYQRvUXAVR-0" />
        <mxCell id="HsMK0yCQirDYQRvUXAVR-1" parent="HsMK0yCQirDYQRvUXAVR-0" />
        <mxCell id="HsMK0yCQirDYQRvUXAVR-2" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;font style=&quot;&quot;&gt;Inventory Service&amp;nbsp;&lt;/font&gt;Sequence Diagram&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;by Abdulwahab ADamson&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Date: 22nd March, 2026&amp;nbsp;&lt;/font&gt;&lt;/div&gt;" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;" vertex="1" parent="HsMK0yCQirDYQRvUXAVR-1">
          <mxGeometry x="40" y="40" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="HsMK0yCQirDYQRvUXAVR-3" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;font style=&quot;font-size: 20px;&quot;&gt;Reflection&lt;/font&gt;&lt;/h1&gt;&lt;p&gt;&lt;font style=&quot;font-size: 14px;&quot;&gt;Working with Product, Inventory, and Wallet Services highlights the importance of separating concerns in software design. Each service handles a specific function: the Product Service manages item details, the Inventory Service tracks stock levels, and the Wallet Service handles user balances and transactions. This separation ensures that each service is scalable and maintainable, allowing for specialized focus on its domain. However, it also requires careful coordination, especially around handling inventory availability, concurrency issues, and financial transactions. For instance, ensuring stock is reserved before a payment is processed and managing secure financial transactions are critical. This setup shows that building reliable systems isn&#39;t just about functionality but also about creating robust, fault-tolerant architectures that can scale effectively. Proper API communication between these services is key to ensuring the system runs smoothly and efficiently.&lt;/font&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" vertex="1" parent="HsMK0yCQirDYQRvUXAVR-1">
          <mxGeometry x="40" y="643" width="1100" height="160" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
